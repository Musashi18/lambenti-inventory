{
  "name": "lambenti-inventory",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "next dev -H 127.0.0.1 -p 5173",
    "build": "next build",
    "start": "next start",
    "start:local": "node scripts/start-local.mjs",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "quality": "npm run lint && npm run typecheck && npm run test && npm run build",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "setup": "powershell -ExecutionPolicy Bypass -File scripts/setup.ps1",
    "agent:orders": "node scripts/alibaba-agent.mjs",
    "agent:order-email": "node scripts/alibaba-order-agent.mjs",
    "agent:alibaba": "node scripts/alibaba-agent.mjs",
    "agent:alibaba-email": "node scripts/alibaba-order-agent.mjs",
    "agent:alibaba-portal": "node scripts/alibaba-portal-agent.mjs",
    "agent:alibaba-login": "node scripts/alibaba-portal-agent.mjs --setup-login",
    "agent:functional": "node scripts/functional-qa-agent.mjs",
    "qa:functional": "node scripts/functional-qa-agent.mjs --skip-quality-gates",
    "smoke": "node scripts/smoke.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "clsx": "^2.1.1",
    "imapflow": "^1.3.6",
    "lucide-react": "^0.511.0",
    "mailparser": "^3.9.9",
    "next": "^15.3.2",
    "pdf-parse": "^2.4.5",
    "playwright-core": "^1.60.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "dotenv": "^16.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8.5.3",
    "prisma": "^6.8.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  }
}
