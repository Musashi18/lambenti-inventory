DATABASE_URL="postgresql://lambenti:lambenti@localhost:55432/lambenti?schema=public"
# Docker Compose publishes Postgres on this host port by default; change both this
# value and DATABASE_URL together if 55432 is unavailable.
LAMBENTI_DB_HOST_PORT="55432"
NEXT_PUBLIC_APP_NAME="Lambenti Inventory"

# Optional: company mailbox IMAP connection for manual supplier order/invoice/payment/shipping email imports.
# Use an app password, not the primary mailbox password.
LAMBENTI_EMAIL_IMAP_HOST="imap.gmail.com"
LAMBENTI_EMAIL_IMAP_PORT="993"
LAMBENTI_EMAIL_IMAP_SECURE="true"
LAMBENTI_EMAIL_IMAP_USER="your-lambenti-google-email@example.com"
LAMBENTI_EMAIL_IMAP_PASSWORD=
LAMBENTI_EMAIL_IMAP_MAILBOX="INBOX"
LAMBENTI_EMAIL_AUTO_APPLY="true"
LAMBENTI_EMAIL_AUTO_CREATE_INVOICE="true"
LAMBENTI_EMAIL_MARK_IMPORTED_SEEN="false"
LAMBENTI_EMAIL_SYNC_MAX_MESSAGES="25"
# Raise this if supplier emails include multiple product/invoice image attachments.
LAMBENTI_EMAIL_MAX_SOURCE_BYTES="10000000"
LAMBENTI_EMAIL_SYNC_SINCE_DAYS="60"
# Optional: require this Bearer token/query secret for /api/integrations/alibaba-email/sync automation.
LAMBENTI_EMAIL_SYNC_SECRET=
# Optional if the app is not served at the default local URL.
LAMBENTI_INVENTORY_BASE_URL="http://127.0.0.1:5173"

# Optional: carrier tracking-status service for `/tracking`.
# Recommended provider for Lambenti: Ship24, because it supports global parcel tracking,
# China Post/EMS/UPS-style imports, courier auto-detection, API/webhooks, and a useful low-volume/free tier.
# Setup: create a Ship24 account/API key, then copy the key into LAMBENTI_TRACKING_STATUS_AUTH_TOKEN.
LAMBENTI_TRACKING_STATUS_PROVIDER="SHIP24"
LAMBENTI_TRACKING_STATUS_AUTH_TOKEN=
LAMBENTI_TRACKING_SHIP24_BASE_URL="https://api.ship24.com"
LAMBENTI_TRACKING_DESTINATION_COUNTRY_CODE="CA"
LAMBENTI_TRACKING_ORIGIN_COUNTRY_CODE=
LAMBENTI_TRACKING_REFRESH_INTERVAL_MINUTES="240"
# Optional bearer token for non-loopback scheduled calls to /api/tracking/refresh.
LAMBENTI_TRACKING_AGENT_SECRET=
# Advanced fallback for non-Ship24/custom JSON tracking APIs. URL template may include
# `{trackingNumber}` and `{carrier}` placeholders. Leave empty when using Ship24.
LAMBENTI_TRACKING_STATUS_URL_TEMPLATE=
LAMBENTI_TRACKING_STATUS_AUTH_HEADER="authorization"

# Optional: direct Alibaba browser portal agent. Run `npm run agent:alibaba-login` once
# to sign in interactively; manual runs reuse this Google Chrome profile/session.
LAMBENTI_ALIBABA_AGENT_SECRET=
LAMBENTI_ALIBABA_ORDERS_URL="https://biz.alibaba.com/order/list.htm"
LAMBENTI_ALIBABA_MESSAGES_URL="https://message.alibaba.com/message/messenger.htm"
LAMBENTI_ALIBABA_BROWSER_PROFILE_DIR="var/alibaba-chrome-profile"
LAMBENTI_ALIBABA_INVOICE_DIR="var/alibaba-invoices"
# Optional if Google Chrome is installed somewhere non-standard.
# LAMBENTI_ALIBABA_BROWSER_EXECUTABLE_PATH="C:/Program Files/Google/Chrome/Application/chrome.exe"
# If Alibaba shows a login form and Chrome autofills saved username/password, submit it automatically.
# This does not and must not bypass CAPTCHA/security checks; those require manual completion.
LAMBENTI_ALIBABA_AUTO_SUBMIT_SAVED_LOGIN="true"
# Assist the headed login page by clicking Alibaba's Google login and Chrome/FedCM's saved
# account button such as "Continue as Musashi". Disable with --no-login-assist if needed.
LAMBENTI_ALIBABA_LOGIN_ASSIST="true"
LAMBENTI_ALIBABA_GOOGLE_CONTINUE_NAME="Musashi"
LAMBENTI_ALIBABA_GOOGLE_CONTINUE_TIMEOUT_MS="12000"
LAMBENTI_ALIBABA_ACCOUNT_CONFIRM_EMAIL="team@lambenti.com"
LAMBENTI_ALIBABA_ACCOUNT_CONFIRM_TIMEOUT_MS="8000"
# During `npm run agent:alibaba-login`, prompt for one-time Alibaba email/password if
# saved Google login is unavailable. Credentials are not stored or logged.
LAMBENTI_ALIBABA_PROMPT_CREDENTIALS="true"
LAMBENTI_ALIBABA_AUTH_SETTLE_MS="2000"
LAMBENTI_ALIBABA_BROWSER_STARTUP_SETTLE_MS="2000"
LAMBENTI_ALIBABA_LOGIN_SETTLE_MS="5000"
# Keep false for reliability; headless logins are more likely to be challenged.
LAMBENTI_ALIBABA_HEADLESS="false"
