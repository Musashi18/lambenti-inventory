generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ItemCategory {
  COMPONENT
  RAW_MATERIAL
  FINISHED_GOOD
  CONSUMABLE
}

enum Unit {
  EACH
  METER
  GRAM
  KILOGRAM
}

enum LifecycleStatus {
  ACTIVE
  NRND
  OBSOLETE
}

enum CostConfidence {
  UNKNOWN
  ESTIMATED
  QUOTED
  CONFIRMED
}

enum MovementType {
  RECEIVE
  CONSUME
  ADJUST
  SCRAP
  RESERVE
  RETURN
}

enum PurchaseRequestStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CONVERTED
}

enum PurchaseOrderStatus {
  DRAFT
  APPROVED
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum AgentActionType {
  READ_STOCK
  READ_BOM
  EVALUATE_SHORTAGE
  COMPARE_SUPPLIERS
  CREATE_DRAFT_PURCHASE_REQUEST
}

enum EmailOrderImportStatus {
  IMPORTED
  APPLIED
  NEEDS_REVIEW
}

enum InvoiceStatus {
  DRAFT
  RECEIVED
  APPROVED
  PAID
  VOID
}

enum CustomerInvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID
}

enum AccountingDocumentStatus {
  UPLOADED
  ANALYZED
  NEEDS_REVIEW
  APPLIED
  ATTACHED
  ARCHIVED
  FAILED
}

enum BankTransactionStatus {
  IMPORTED
  MATCHED
  IGNORED
}

enum GLAccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
  COGS
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOID
}

enum JournalEntryKind {
  AP_INVOICE
  AP_PAYMENT
  MANUAL
  REVERSAL
}

enum UserRole {
  ADMIN
  OPERATIONS
  PURCHASING
  ACCOUNTING
  VIEWER
  AGENT
}

enum AutomationRunKind {
  STOCK_REORDER_SCAN
  BOM_SHORTAGE_SCAN
  SUPPLIER_EMAIL_SYNC
  ALIBABA_PORTAL_SYNC
  INVOICE_RECONCILIATION
  PO_RECONCILIATION
  INVENTORY_ANOMALY_SCAN
  CYCLE_COUNT_PLANNER
  SUPPLIER_SCORE_REFRESH
}

enum AutomationRunStatus {
  RUNNING
  SUCCEEDED
  PARTIAL
  FAILED
}

enum AutomationFindingSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AutomationFindingStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

model Item {
  id                   String                 @id @default(cuid())
  sku                  String                 @unique
  manufacturerPartNo   String?
  supplierSku          String?
  description          String
  category             ItemCategory
  unit                 Unit
  reorderPoint         Int
  targetStock          Int
  leadTimeDays         Int
  lifecycleStatus      LifecycleStatus        @default(ACTIVE)
  storageLocationId    String
  storageLocation      StorageLocation        @relation(fields: [storageLocationId], references: [id])
  estimatedUnitCost    Decimal?               @db.Decimal(10, 2)
  costCurrency         String                 @default("USD")
  costConfidence       CostConfidence         @default(UNKNOWN)
  costSourceRef        String?
  preferredSupplierId  String?
  preferredSupplier    Supplier?              @relation("PreferredSupplier", fields: [preferredSupplierId], references: [id])
  supplierOffers       SupplierOffer[]
  bomParents           BOM[]                  @relation("BomParent")
  bomLines             BOMLine[]              @relation("BomComponent")
  stockLots            StockLot[]
  stockMovements       StockMovement[]
  purchaseRequestLines PurchaseRequestLine[]
  purchaseOrderLines   PurchaseOrderLine[]
  emailOrderLines      EmailOrderLineImport[]
  invoiceLines         SupplierInvoiceLine[]
  customerInvoiceLines CustomerInvoiceLine[]
  reservations         BuildReservation[]
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
}

model StorageLocation {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  items       Item[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Supplier {
  id                    String               @id @default(cuid())
  name                  String               @unique
  confirmedByHuman      Boolean              @default(false)
  companyName           String?
  contactEmail          String?
  contactName           String?
  taxRegistrationNumber String?
  companyRevenue        Decimal?             @db.Decimal(14, 2)
  foundedYear           Int?
  address               String?
  moq                   Int
  leadTimeDays          Int
  shippingCost          Decimal              @db.Decimal(10, 2)
  reliabilityScore      Decimal              @db.Decimal(5, 2)
  productPageUrl        String?
  archivedAt            DateTime?
  archivedBy            String?
  archiveReason         String?
  preferredFor          Item[]               @relation("PreferredSupplier")
  offers                SupplierOffer[]
  purchaseRequests      PurchaseRequest[]
  purchaseOrders        PurchaseOrder[]
  invoices              SupplierInvoice[]
  accountingDocuments   AccountingDocument[]
  emailOrderImports     EmailOrderImport[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([archivedAt])
}

model SupplierOffer {
  id             String   @id @default(cuid())
  itemId         String
  supplierId     String
  supplierSku    String
  productPageUrl String?
  leadTimeDays   Int
  moq            Int
  pricingTiers   Json
  currency       String
  item           Item     @relation(fields: [itemId], references: [id])
  supplier       Supplier @relation(fields: [supplierId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([itemId, supplierId])
}

model BOM {
  id           String    @id @default(cuid())
  parentItemId String
  version      String
  active       Boolean   @default(true)
  parentItem   Item      @relation("BomParent", fields: [parentItemId], references: [id])
  lines        BOMLine[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([parentItemId, version])
}

model BOMLine {
  id              String @id @default(cuid())
  bomId           String
  componentItemId String
  quantity        Int
  bom             BOM    @relation(fields: [bomId], references: [id])
  componentItem   Item   @relation("BomComponent", fields: [componentItemId], references: [id])
}

model StockLot {
  id         String          @id @default(cuid())
  itemId     String
  lotCode    String
  receivedAt DateTime
  unitCost   Decimal         @db.Decimal(10, 2)
  currency   String          @default("USD")
  item       Item            @relation(fields: [itemId], references: [id])
  movements  StockMovement[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([itemId, lotCode])
}

model StockMovement {
  id                  String             @id @default(cuid())
  itemId              String
  stockLotId          String?
  purchaseOrderLineId String?
  movementType        MovementType
  quantity            Int
  reason              String
  reference           String?
  actorType           String
  actorId             String
  createdAt           DateTime           @default(now())
  item                Item               @relation(fields: [itemId], references: [id])
  stockLot            StockLot?          @relation(fields: [stockLotId], references: [id])
  purchaseOrderLine   PurchaseOrderLine? @relation(fields: [purchaseOrderLineId], references: [id])

  @@index([itemId, createdAt])
  @@index([stockLotId, createdAt])
  @@index([purchaseOrderLineId])
}

model PurchaseRequest {
  id            String                @id @default(cuid())
  supplierId    String?
  status        PurchaseRequestStatus @default(DRAFT)
  rationale     String
  requestedBy   String
  approvedBy    String?
  approvedAt    DateTime?
  supplier      Supplier?             @relation(fields: [supplierId], references: [id])
  lines         PurchaseRequestLine[]
  purchaseOrder PurchaseOrder?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
}

model PurchaseRequestLine {
  id                String          @id @default(cuid())
  purchaseRequestId String
  itemId            String
  quantity          Int
  targetUnitPrice   Decimal?        @db.Decimal(10, 2)
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id])
  item              Item            @relation(fields: [itemId], references: [id])
}

model PurchaseOrder {
  id                  String               @id @default(cuid())
  supplierId          String
  purchaseRequestId   String?              @unique
  status              PurchaseOrderStatus  @default(DRAFT)
  orderedAt           DateTime?
  expectedAt          DateTime?
  supplier            Supplier             @relation(fields: [supplierId], references: [id])
  purchaseRequest     PurchaseRequest?     @relation(fields: [purchaseRequestId], references: [id])
  lines               PurchaseOrderLine[]
  emailOrderImports   EmailOrderImport[]
  trackingNumbers     TrackingNumber[]
  invoices            SupplierInvoice[]
  accountingDocuments AccountingDocument[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model PurchaseOrderLine {
  id               String                @id @default(cuid())
  purchaseOrderId  String
  itemId           String
  quantity         Int
  unitPrice        Decimal               @db.Decimal(10, 2)
  receivedQuantity Int                   @default(0)
  purchaseOrder    PurchaseOrder         @relation(fields: [purchaseOrderId], references: [id])
  item             Item                  @relation(fields: [itemId], references: [id])
  stockMovements   StockMovement[]
  invoiceLines     SupplierInvoiceLine[]
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  name      String?
  role      UserRole @default(VIEWER)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

model AgentAction {
  id         String          @id @default(cuid())
  actionType AgentActionType
  agentName  String
  payload    Json
  result     Json?
  createdAt  DateTime        @default(now())
}

model AutomationRun {
  id           String              @id @default(cuid())
  kind         AutomationRunKind
  status       AutomationRunStatus @default(RUNNING)
  startedAt    DateTime            @default(now())
  finishedAt   DateTime?
  actorType    String
  actorId      String
  inputHash    String?
  summaryJson  Json?
  errorMessage String?
  findings     AutomationFinding[]
  createdAt    DateTime            @default(now())

  @@index([kind, createdAt])
  @@index([status, createdAt])
  @@index([actorId, createdAt])
}

model AutomationFinding {
  id                  String                    @id @default(cuid())
  automationRunId     String
  automationRun       AutomationRun             @relation(fields: [automationRunId], references: [id], onDelete: Cascade)
  severity            AutomationFindingSeverity
  category            String
  entityType          String
  entityId            String
  title               String
  message             String
  suggestedActionType String?
  suggestedActionJson Json?
  status              AutomationFindingStatus   @default(OPEN)
  dedupeKey           String?                   @unique
  createdAt           DateTime                  @default(now())
  resolvedAt          DateTime?

  @@index([status, severity])
  @@index([category])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model EmailOrderImport {
  id                  String                 @id @default(cuid())
  source              String                 @default("SYNCED_EMAIL")
  sourceHash          String                 @unique
  sourceMessageId     String?
  sourceUrl           String?
  subject             String?
  fromAddress         String?
  rawText             String
  externalOrderId     String?
  supplierName        String
  supplierId          String?
  supplier            Supplier?              @relation(fields: [supplierId], references: [id])
  orderDate           DateTime?
  currency            String                 @default("USD")
  subtotal            Decimal?               @db.Decimal(12, 2)
  shippingCost        Decimal?               @db.Decimal(12, 2)
  taxCost             Decimal?               @db.Decimal(12, 2)
  totalCost           Decimal?               @db.Decimal(12, 2)
  status              EmailOrderImportStatus @default(IMPORTED)
  confidence          CostConfidence         @default(ESTIMATED)
  purchaseOrderId     String?
  purchaseOrder       PurchaseOrder?         @relation(fields: [purchaseOrderId], references: [id])
  invoiceDocumentPath String?
  invoiceDocumentHash String?
  invoiceDocumentText String?
  invoiceDownloadedAt DateTime?
  archivedAt          DateTime?
  archivedBy          String?
  archiveReason       String?
  lines               EmailOrderLineImport[]
  trackingNumbers     TrackingNumber[]
  accountingDocuments AccountingDocument[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@index([externalOrderId])
  @@index([source])
  @@index([archivedAt])
  @@index([createdAt])
}

model EmailOrderLineImport {
  id                String           @id @default(cuid())
  importId          String
  import            EmailOrderImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  lineNo            Int
  rawDescription    String
  supplierSku       String?
  productUrl        String?
  quantity          Int
  unitPrice         Decimal?         @db.Decimal(12, 4)
  lineTotal         Decimal?         @db.Decimal(12, 2)
  shippingAllocated Decimal?         @db.Decimal(12, 2)
  taxAllocated      Decimal?         @db.Decimal(12, 2)
  landedUnitCost    Decimal?         @db.Decimal(12, 4)
  currency          String           @default("USD")
  matchedItemId     String?
  matchedItem       Item?            @relation(fields: [matchedItemId], references: [id])
  matchConfidence   String           @default("UNMATCHED")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([importId, lineNo])
  @@index([matchedItemId])
}

model SupplierInvoice {
  id                      String                             @id @default(cuid())
  invoiceNumber           String
  invoiceNumberKey        String
  supplierId              String
  purchaseOrderId         String?
  status                  InvoiceStatus                      @default(DRAFT)
  currency                String                             @default("USD")
  subtotal                Decimal                            @db.Decimal(12, 2)
  shippingCost            Decimal                            @default(0) @db.Decimal(12, 2)
  taxCost                 Decimal                            @default(0) @db.Decimal(12, 2)
  taxJurisdiction         String?
  taxRate                 Decimal?                           @db.Decimal(6, 4)
  taxRecoverableAmount    Decimal?                           @db.Decimal(12, 2)
  taxNonRecoverableAmount Decimal?                           @db.Decimal(12, 2)
  dutyCost                Decimal                            @default(0) @db.Decimal(12, 2)
  brokerageCost           Decimal                            @default(0) @db.Decimal(12, 2)
  otherLandedCost         Decimal                            @default(0) @db.Decimal(12, 2)
  total                   Decimal                            @db.Decimal(12, 2)
  sourceCurrency          String?
  sourceSubtotal          Decimal?                           @db.Decimal(12, 2)
  sourceTaxCost           Decimal?                           @db.Decimal(12, 2)
  sourceTotal             Decimal?                           @db.Decimal(12, 2)
  invoiceDate             DateTime                           @default(now())
  dueDate                 DateTime?
  sourceDocumentPath      String?
  sourceDocumentHash      String?
  externalSourceUrl       String?
  notes                   String?
  approvalNotes           String?
  approvedBy              String?
  approvedAt              DateTime?
  paymentReference        String?
  paidBy                  String?
  paidAt                  DateTime?
  voidReason              String?
  supplier                Supplier                           @relation(fields: [supplierId], references: [id])
  purchaseOrder           PurchaseOrder?                     @relation(fields: [purchaseOrderId], references: [id])
  lines                   SupplierInvoiceLine[]
  accountingDocuments     AccountingDocument[]
  paymentAllocations      SupplierInvoicePaymentAllocation[]
  journalEntries          JournalEntry[]
  createdAt               DateTime                           @default(now())
  updatedAt               DateTime                           @updatedAt

  @@unique([supplierId, invoiceNumberKey])
  @@index([invoiceNumber])
  @@index([supplierId])
  @@index([purchaseOrderId])
  @@index([status])
  @@index([invoiceDate])
}

model SupplierInvoiceLine {
  id                  String             @id @default(cuid())
  invoiceId           String
  itemId              String?
  purchaseOrderLineId String?
  glAccountId         String?
  description         String
  quantity            Int
  unitPrice           Decimal            @db.Decimal(12, 4)
  lineTotal           Decimal            @db.Decimal(12, 2)
  invoice             SupplierInvoice    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  item                Item?              @relation(fields: [itemId], references: [id])
  purchaseOrderLine   PurchaseOrderLine? @relation(fields: [purchaseOrderLineId], references: [id], onDelete: SetNull)
  glAccount           GLAccount?         @relation(fields: [glAccountId], references: [id], onDelete: SetNull)

  @@index([purchaseOrderLineId])
  @@index([glAccountId])
}

model AccountingDocument {
  id                 String                   @id @default(cuid())
  source             String                   @default("MANUAL_UPLOAD")
  sourceKind         String                   @default("UPLOAD")
  originalFileName   String
  storedPath         String
  sha256             String                   @unique
  mimeType           String
  sizeBytes          Int
  extractedText      String?
  analysisJson       Json?
  status             AccountingDocumentStatus @default(UPLOADED)
  errorMessage       String?
  uploadedBy         String?
  supplierId         String?
  supplier           Supplier?                @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  purchaseOrderId    String?
  purchaseOrder      PurchaseOrder?           @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  supplierInvoiceId  String?
  supplierInvoice    SupplierInvoice?         @relation(fields: [supplierInvoiceId], references: [id], onDelete: SetNull)
  emailOrderImportId String?
  emailOrderImport   EmailOrderImport?        @relation(fields: [emailOrderImportId], references: [id], onDelete: SetNull)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([status, createdAt])
  @@index([supplierId])
  @@index([purchaseOrderId])
  @@index([supplierInvoiceId])
  @@index([emailOrderImportId])
}

model BankTransaction {
  id           String                             @id @default(cuid())
  source       String
  sourceHash   String                             @unique
  accountName  String?
  postedAt     DateTime
  description  String
  counterparty String?
  currency     String                             @default("USD")
  amount       Decimal                            @db.Decimal(12, 2)
  reference    String?
  status       BankTransactionStatus              @default(IMPORTED)
  allocations  SupplierInvoicePaymentAllocation[]
  createdAt    DateTime                           @default(now())
  updatedAt    DateTime                           @updatedAt

  @@index([postedAt])
  @@index([status])
  @@index([reference])
}

model SupplierInvoicePaymentAllocation {
  id                String           @id @default(cuid())
  supplierInvoiceId String
  bankTransactionId String?
  amount            Decimal          @db.Decimal(12, 2)
  currency          String           @default("USD")
  paymentDate       DateTime
  reference         String
  reconciledBy      String
  reconciledAt      DateTime         @default(now())
  notes             String?
  supplierInvoice   SupplierInvoice  @relation(fields: [supplierInvoiceId], references: [id], onDelete: Cascade)
  bankTransaction   BankTransaction? @relation(fields: [bankTransactionId], references: [id], onDelete: SetNull)
  journalEntry      JournalEntry?

  @@unique([supplierInvoiceId, bankTransactionId])
  @@index([supplierInvoiceId])
  @@index([bankTransactionId])
}

model GLAccount {
  id           String                @id @default(cuid())
  code         String                @unique
  name         String
  type         GLAccountType
  active       Boolean               @default(true)
  mappings     GLAccountMapping[]
  invoiceLines SupplierInvoiceLine[]
  journalLines JournalEntryLine[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}

model GLAccountMapping {
  id          String    @id @default(cuid())
  scopeType   String
  scopeId     String?
  purpose     String
  glAccountId String
  priority    Int       @default(100)
  active      Boolean   @default(true)
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  glAccount   GLAccount @relation(fields: [glAccountId], references: [id])

  @@index([scopeType, scopeId])
  @@index([purpose])
  @@index([glAccountId])
}

model JournalEntry {
  id                                 String                            @id @default(cuid())
  entryNumber                        String                            @unique
  idempotencyKey                     String                            @unique
  kind                               JournalEntryKind
  status                             JournalEntryStatus                @default(DRAFT)
  entryDate                          DateTime
  currency                           String                            @default("USD")
  totalDebit                         Decimal                           @default(0) @db.Decimal(14, 2)
  totalCredit                        Decimal                           @default(0) @db.Decimal(14, 2)
  memo                               String?
  sourceType                         String
  sourceId                           String
  sourceReference                    String?
  supplierInvoiceId                  String?
  supplierInvoice                    SupplierInvoice?                  @relation(fields: [supplierInvoiceId], references: [id], onDelete: Restrict)
  supplierInvoicePaymentAllocationId String?                           @unique
  supplierInvoicePaymentAllocation   SupplierInvoicePaymentAllocation? @relation(fields: [supplierInvoicePaymentAllocationId], references: [id], onDelete: Restrict)
  reversesJournalEntryId             String?                           @unique
  reversesJournalEntry               JournalEntry?                     @relation("JournalEntryReversal", fields: [reversesJournalEntryId], references: [id], onDelete: Restrict)
  reversalJournalEntry               JournalEntry?                     @relation("JournalEntryReversal")
  createdBy                          String
  postedBy                           String?
  postedAt                           DateTime?
  voidedBy                           String?
  voidedAt                           DateTime?
  voidReason                         String?
  lines                              JournalEntryLine[]
  createdAt                          DateTime                          @default(now())
  updatedAt                          DateTime                          @updatedAt

  @@index([status, entryDate])
  @@index([kind, entryDate])
  @@index([sourceType, sourceId])
  @@index([supplierInvoiceId])
}

model JournalEntryLine {
  id                  String        @id @default(cuid())
  journalEntryId      String
  lineNo              Int
  glAccountId         String
  accountCodeSnapshot String
  accountNameSnapshot String
  accountTypeSnapshot GLAccountType
  description         String
  debit               Decimal       @default(0) @db.Decimal(14, 2)
  credit              Decimal       @default(0) @db.Decimal(14, 2)
  sourceLineType      String?
  sourceLineId        String?
  journalEntry        JournalEntry  @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  glAccount           GLAccount     @relation(fields: [glAccountId], references: [id], onDelete: Restrict)

  @@unique([journalEntryId, lineNo])
  @@index([glAccountId])
  @@index([sourceLineType, sourceLineId])
}

model Customer {
  id                    String            @id @default(cuid())
  name                  String            @unique
  companyName           String?
  contactEmail          String?
  taxRegistrationNumber String?
  invoices              CustomerInvoice[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
}

model CustomerInvoice {
  id               String                @id @default(cuid())
  invoiceNumber    String                @unique
  customerId       String
  status           CustomerInvoiceStatus @default(DRAFT)
  currency         String                @default("CAD")
  subtotal         Decimal               @db.Decimal(12, 2)
  taxCost          Decimal               @default(0) @db.Decimal(12, 2)
  total            Decimal               @db.Decimal(12, 2)
  invoiceDate      DateTime              @default(now())
  dueDate          DateTime?
  notes            String?
  sentBy           String?
  sentAt           DateTime?
  paymentReference String?
  paidBy           String?
  paidAt           DateTime?
  voidReason       String?
  customer         Customer              @relation(fields: [customerId], references: [id])
  lines            CustomerInvoiceLine[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([invoiceDate])
}

model CustomerInvoiceLine {
  id                String          @id @default(cuid())
  customerInvoiceId String
  itemId            String?
  description       String
  quantity          Int
  unitPrice         Decimal         @db.Decimal(12, 4)
  taxRate           Decimal?        @db.Decimal(6, 4)
  lineTotal         Decimal         @db.Decimal(12, 2)
  taxAmount         Decimal         @default(0) @db.Decimal(12, 2)
  customerInvoice   CustomerInvoice @relation(fields: [customerInvoiceId], references: [id], onDelete: Cascade)
  item              Item?           @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([itemId])
}

model BuildReservation {
  id        String   @id @default(cuid())
  itemId    String
  buildName String
  quantity  Int
  dueDate   DateTime
  item      Item     @relation(fields: [itemId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TrackingNumber {
  id                 String           @id @default(cuid())
  trackingNumber     String           @unique
  carrier            String?
  provider           String           @default("UNCONFIGURED")
  currentStatus      String           @default("UNKNOWN")
  statusDescription  String?
  origin             String?
  destination        String?
  source             String           @default("MANUAL")
  sourceUrl          String?
  externalOrderId    String?
  supplierName       String?
  purchaseOrderId    String?
  purchaseOrder      PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id])
  emailOrderImportId String?
  emailOrderImport   EmailOrderImport? @relation(fields: [emailOrderImportId], references: [id], onDelete: SetNull)
  lastEventAt        DateTime?
  deliveredAt        DateTime?
  lastCheckedAt      DateTime?
  nextRefreshAt      DateTime?
  refreshStatus      String           @default("PENDING")
  refreshError       String?
  rawStatusJson      Json?
  capturedAt         DateTime         @default(now())
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  events             TrackingEvent[]

  @@index([externalOrderId])
  @@index([purchaseOrderId])
  @@index([emailOrderImportId])
  @@index([currentStatus])
  @@index([nextRefreshAt])
  @@index([updatedAt])
}

model TrackingEvent {
  id               String         @id @default(cuid())
  trackingNumberId String
  trackingNumber   TrackingNumber @relation(fields: [trackingNumberId], references: [id], onDelete: Cascade)
  status           String?
  description      String
  location         String?
  occurredAt       DateTime?
  rawEventJson     Json?
  createdAt        DateTime       @default(now())

  @@index([trackingNumberId, occurredAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorType  String
  actorId    String
  action     String
  entityType String
  entityId   String
  payload    Json
  createdAt  DateTime @default(now())
}
